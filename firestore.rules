rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // User Profile Rules
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null || userId == 'demo-student-alice' || userId.startsWith('mentor-');
    }
    
    // Project Submissions Rules
    match /projects/{projectId} {
      allow read: if true;
      allow write: if true;
    }
    
    // Support Queries Rules
    match /queries/{queryId} {
      allow read, write: if true;
    }
  }
}
